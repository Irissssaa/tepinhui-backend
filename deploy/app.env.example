# 复制到服务器: ${DEPLOY_PATH}/shared/app.env
# 修改以下值以匹配你的环境

# 服务配置
APP_HOST=127.0.0.1
APP_PORT=8060
JAVA_OPTS="-Xms256m -Xmx512m"
# API 前缀：所有 REST 端点的 URL 都会加上此前缀
# 例如: /tph/auth/login, /tph/products
APP_API_PREFIX=/tph
# 健康检查端点路径（相对于 API 前缀）
# 例如 APP_API_PREFIX=/tph 且 APP_HEALTH_ENDPOINT=/health 时，
# 健康检查地址为 http://127.0.0.1:8060/tph/health
APP_HEALTH_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=5
STARTUP_TIMEOUT=120
# 自动回滚脚本使用的健康检查超时
HEALTH_TIMEOUT=60

# 日志读取配置
# 注意：deploy.sh 和 systemd 模板默认会把服务日志写入同一路径。
# 如果修改 APP_LOG_FILE_PATH，必须同步修改 deploy.sh / tepinhui-backend.service
# 中的日志输出路径，避免“接口读取路径”和“实际落盘路径”不一致。
APP_LOG_FILE_PATH=/home/tph/shared/logs/tepinhui-backend/application.log
# 管理端 GET /tph/api/v1/admin/logs 未传 limit 时使用此默认值
APP_LOG_READ_DEFAULT_LIMIT=100
# 管理端 GET /tph/api/v1/admin/logs 的 limit 允许上限，超出会被拒绝
APP_LOG_READ_MAX_LIMIT=500

# Spring 配置
SPRING_PROFILES_ACTIVE=prod

# 数据库配置
DB_PASSWORD=replace-me
REDIS_PASSWORD=

# JWT 配置
JWT_SECRET=replace-me-with-a-long-random-secret

# 邮件服务配置 (SMTP)
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USERNAME=your_email@163.com
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@tepinhui.com

# 可选：部署保留的历史版本数量
# MAX_VERSIONS=5
